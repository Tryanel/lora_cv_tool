        <mxCell id="p3_note" value="说明：后端图按业务行分组，每行只画相邻调用，避免跨行穿过服务框。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#6b7280;" vertex="1" parent="1">
          <mxGeometry x="40" y="870" width="900" height="38" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
